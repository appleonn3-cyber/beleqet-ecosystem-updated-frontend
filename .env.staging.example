# =============================================================================
# Beleqet staging environment — TEMPLATE (placeholders only, never real values)
#
# Copy to /srv/beleqet-staging/.env.staging ON THE STAGING SERVER, fill in real
# values there, and never commit the filled file. docker-compose.staging.yml
# refuses to render when a required variable is missing.
#
# Generate strong secrets with:  openssl rand -hex 64   (or -hex 32 for keys)
# =============================================================================

# ── Application environment ──────────────────────────────────────────────────
# NODE_ENV inside containers is fixed by the compose file (staging/production).
SWAGGER_ENABLED=false
TOTP_ISSUER=Beleqet

# ── Backend URL ──────────────────────────────────────────────────────────────
# Public base URL of the staging backend (used for OAuth callbacks etc.)
STAGING_APP_BASE_URL=https://staging-api.example.com

# ── Frontend URLs ────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins (admin + jobs frontends)
STAGING_FRONTEND_URLS=https://staging-admin.example.com,https://staging-jobs.example.com

# ── Host ports (published on the staging server) ─────────────────────────────
STAGING_BACKEND_PORT=4000
STAGING_ADMIN_PORT=3000
STAGING_JOBS_PORT=3001

# ── Database (PostgreSQL container) ──────────────────────────────────────────
STAGING_DB_USER=beleqet_staging
STAGING_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
STAGING_DB_NAME=beleqet_staging

# ── Redis ────────────────────────────────────────────────────────────────────
# The bundled Redis container listens only on the compose network and has no
# password; point the backend elsewhere only if you use managed Redis.

# ── JWT and security ─────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_SECRET
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
SESSION_SECRET=REPLACE_WITH_64_CHAR_SECRET

# ── TOTP (two-factor authentication) ─────────────────────────────────────────
TOTP_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS
TOTP_TEMP_SECRET=REPLACE_WITH_64_CHAR_SECRET

# ── OAuth (ALL REQUIRED — the auth module refuses to boot without them) ──────
# Key: openssl rand -base64 32  (must decode to exactly 32 bytes)
OAUTH_TOKEN_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=https://staging-api.example.com/api/v1/auth/google/callback
LINKEDIN_CLIENT_ID=REPLACE_WITH_LINKEDIN_CLIENT_ID
LINKEDIN_CLIENT_SECRET=REPLACE_WITH_LINKEDIN_CLIENT_SECRET
LINKEDIN_CALLBACK_URL=https://staging-api.example.com/api/v1/auth/linkedin/callback

# ── Payments (REQUIRED — payment services boot-check these) ──────────────────
# Use TEST/SANDBOX keys on staging, never live keys.
STRIPE_SECRET_KEY=REPLACE_WITH_STRIPE_TEST_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_STRIPE_TEST_WEBHOOK_SECRET
PAYPAL_CLIENT_ID=REPLACE_WITH_PAYPAL_SANDBOX_CLIENT_ID
PAYPAL_CLIENT_SECRET=REPLACE_WITH_PAYPAL_SANDBOX_CLIENT_SECRET
CHAPA_SECRET_KEY=
CHAPA_PUBLIC_KEY=
CHAPA_WEBHOOK_SECRET=
CHAPA_CALLBACK_URL=https://staging-api.example.com/api/v1/escrow/callback
CHAPA_RETURN_URL=https://staging-jobs.example.com/freelance/payment-success

# ── AI providers (optional on staging) ───────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Object storage (Cloudflare R2 / S3-compatible) ───────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# ── Email (REQUIRED — the mail module boot-checks the full set) ──────────────
SMTP_HOST=REPLACE_WITH_SMTP_HOST
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_SMTP_USER
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
SMTP_FROM_ADDRESS=noreply@example.com
SMTP_SECURE=false
SMTP_FROM=Beleqet Staging <noreply@example.com>

# ── Admin dashboards ─────────────────────────────────────────────────────────
BULL_BOARD_USERNAME=
BULL_BOARD_PASSWORD=

# ── Container registry (for docker login on the staging server) ──────────────
# Values mirror the GitHub Environment secrets STAGING_GHCR_USERNAME/TOKEN;
# the deploy script logs in before pulling images.
GHCR_REGISTRY=ghcr.io
GHCR_USERNAME=REPLACE_WITH_GITHUB_USERNAME
GHCR_TOKEN=REPLACE_WITH_READ_PACKAGES_TOKEN
# Image repository prefix, e.g. ghcr.io/<owner>/<repo-name>
IMAGE_NAMESPACE=ghcr.io/nathnaelmesfin/beleqet-ecosystem-updated

# ── Image tag (managed by the deploy script — do not set manually) ───────────
# BACKEND_IMAGE / ADMIN_IMAGE / JOBS_IMAGE are written to .env.images by
# scripts/deploy/deploy-staging.sh using the exact commit SHA.

# ── Health-check URLs (probed after deployment) ──────────────────────────────
HEALTH_URL_BACKEND=http://127.0.0.1:4000/api/v1/health/ready
HEALTH_URL_ADMIN=http://127.0.0.1:3000/
HEALTH_URL_JOBS=http://127.0.0.1:3001/
