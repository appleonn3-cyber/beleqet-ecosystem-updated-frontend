{
  "name": "beleqet-backend",
  "version": "1.0.0",
  "description": "Beleqet Backend Service",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"tools/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"tools/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"tools/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"tools/**/*.ts\" --fix",
    "test": "jest --testPathIgnorePatterns=\"integration\\.spec\\.ts$\" --passWithNoTests",
    "test:watch": "jest --watch --testPathIgnorePatterns=\"integration\\.spec\\.ts$\"",
    "test:cov": "jest --coverage --testPathIgnorePatterns=\"integration\\.spec\\.ts$\"",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:ci-cd": "jest --config ./test/jest-ci-cd.json --runInBand",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.4.1",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.1",
    "@nestjs/event-emitter": "^2.0.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.1",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^5.22.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.13.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "connect-redis": "^9.0.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "mammoth": "^1.12.0",
    "nestjs-i18n": "^10.8.4",
    "nodemailer": "^9.0.3",
    "openai": "^4.57.0",
    "otplib": "^13.4.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "passport-openidconnect": "^0.1.2",
    "paypal-rest-sdk": "^1.8.1",
    "pdf-parse": "^2.4.5",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "redis": "^6.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.35.3",
    "socket.io": "^4.8.3",
    "stripe": "^16.12.0",
    "telegraf": "^4.16.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.1",
    "@playwright/test": "^1.61.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^4.10.4",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.19.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.5.5",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/paypal-rest-sdk": "^1.7.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^7.2.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2",
    "vite": "^6.4.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts",
      "tsx",
      "jsx"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)sx?$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@common/(.*)$": "<rootDir>/common/$1",
      "^@modules/(.*)$": "<rootDir>/modules/$1",
      "^@prisma-client$": "<rootDir>/prisma/prisma.service"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(otplib|@otplib|@scure|@noble)/)"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
